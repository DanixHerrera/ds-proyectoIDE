<Window x:Class="StudentIDE.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        mc:Ignorable="d"
        Title="StudentIDE"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen">

	<!--
        ESTRUCTURA PRINCIPAL DE LA VENTANA
        Dividida en 3 zonas verticales:
          1. Barra superior (menú + acciones)
          2. Zona central (panel de archivos | editor | terminal)
          3. Barra de estado inferior
    -->
	<Grid>
		<Grid.RowDefinitions>
			<!-- Fila 0: Barra superior -->
			<RowDefinition Height="40"/>
			<!-- Fila 1: Zona de trabajo principal -->
			<RowDefinition Height="*"/>
			<!-- Fila 2: Barra de estado -->
			<RowDefinition Height="25"/>
		</Grid.RowDefinitions>

		<!-- ═══════════════════════════════════════════════════════ -->
		<!-- FILA 0: Barra superior                                 -->
		<!-- RF-11: Botón Guardar + atajo Ctrl+S                   -->
		<!-- Aquí irán más acciones: Ejecutar (RF-12), Entregar (RF-22) -->
		<!-- ═══════════════════════════════════════════════════════ -->
		<Border Grid.Row="0" Background="#2D2D2D">
			<StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0">
                <Button Content="📂 Abrir"
                        Command="{Binding AbrirCommand}"
                        Background="#3C3C3C"
                        Foreground="White"
                        BorderBrush="#555"
                        Padding="10,4"
                        Margin="0,0,8,0"
                        Cursor="Hand"
                        ToolTip="Abrir archivo"/>
				<!-- Botón Guardar (RF-11) -->
				<Button Content="💾 Guardar"
                        Command="{Binding GuardarCommand}"
                        Background="#3C3C3C"
                        Foreground="White"
                        BorderBrush="#555"
                        Padding="10,4"
                        Margin="0,0,8,0"
                        Cursor="Hand"
                        ToolTip="Guardar archivo (Ctrl+S)"/>
				<!-- TODO RF-12: Botón Ejecutar -->
				<Button Content="▶ Ejecutar"
                        Command="{Binding EjecutarCommand}"
                        Background="#3C3C3C"
                        Foreground="White"
                        BorderBrush="#555"
                        Padding="10,4"
                        Margin="0,0,8,0"
                        Cursor="Hand"
                        ToolTip="Ejecutar (F5)"/>
				<!-- TODO RF-22: Botón Entregar Tarea -->
				<!-- <Button Content="📤 Entregar Tarea" .../> -->
			</StackPanel>
		</Border>

		<!-- ═══════════════════════════════════════════ -->
		<!-- FILA 1: Zona central dividida en 3 columnas -->
		<!-- ═══════════════════════════════════════════ -->
		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<!-- Col 0: Panel lateral de archivos/proyectos -->
				<ColumnDefinition Width="200"/>
				<!-- Col 1: Editor de código (RF-05) -->
				<ColumnDefinition Width="*"/>
				<!-- Col 2: Panel de tareas (RF-06) -->
				<ColumnDefinition Width="250"/>
			</Grid.ColumnDefinitions>

			<!-- ─────────────────────────────────── -->
			<!-- COL 0: Panel de archivos/proyectos  -->
			<!-- Gestor de proyectos (RF-09)          -->
			<!-- ─────────────────────────────────── -->
			<Border Grid.Column="0" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,1,0">
				<StackPanel Margin="8">
					<TextBlock Text="EXPLORADOR" Foreground="#AAAAAA" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
					<!-- Aquí irá el TreeView de proyectos y archivos (RF-09, RF-10) -->
					<TextBlock Text="[Panel de proyectos — pendiente]" Foreground="#555" FontSize="11" TextWrapping="Wrap"/>
				</StackPanel>
			</Border>

			<!-- ─────────────────────────────────── -->
			<!-- COL 1: Editor de código             -->
			<!-- RF-05: Área de edición de código    -->
			<!-- Por ahora: TextBox simple            -->
			<!-- Aquí se integrará AvalonEdit después -->
			<!-- ─────────────────────────────────── -->
			<Grid Grid.Column="1">
				<Grid.RowDefinitions>
					<!-- Zona del editor -->
					<RowDefinition Height="*"/>
					<!-- Separador arrastrabe -->
					<RowDefinition Height="5"/>
					<!-- Terminal interactiva (RF-16) -->
					<RowDefinition Height="180"/>
				</Grid.RowDefinitions>

				<!-- ─────────────────────────────────────────────────────── -->
				<!-- COL 1: Editor de código — RF-05                        -->
				<!-- AvalonEdit: syntax highlighting Python, núm. de línea, -->
				<!-- resaltado de línea activa, tema oscuro                 -->
				<!-- NOTA: Text de AvalonEdit no es DependencyProperty,     -->
				<!-- la sincronización con el ViewModel se hace en          -->
				<!-- MainView.xaml.cs mediante el evento TextChanged.       -->
				<!-- ─────────────────────────────────────────────────────── -->
				<avalonedit:TextEditor
                    x:Name="CodeEditor"
                    Grid.Row="0"
                    FontFamily="Consolas"
                    FontSize="14"
                    Background="#1E1E1E"
                    Foreground="#D4D4D4"
                    LineNumbersForeground="#858585"
                    ShowLineNumbers="True"
                    WordWrap="False"
                    IsReadOnly="False"
                    SyntaxHighlighting="Python"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto"
                    Padding="4,0,0,0"/>

				<!-- Divisor visual entre editor y terminal -->
				<GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#3C3C3C"/>

				<!-- Terminal interactiva (RF-16) — espacio reservado -->
				<Border Grid.Row="2" Background="#0C0C0C">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>
						
						<TextBlock Grid.Row="0" Text="TERMINAL" Foreground="#AAAAAA" FontSize="11" FontWeight="Bold" Margin="10,6,0,4"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
						    <TextBox Text="{Binding SalidaTerminal, Mode=OneWay}"
                                     Foreground="#CCCCCC" 
                                     Background="Transparent"
                                     BorderBrush="Transparent"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Margin="10,0"/>
                        </ScrollViewer>
						
						<Grid Grid.Row="2">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							
							<TextBlock Grid.Column="0" Text=">" Foreground="#00FF00" FontFamily="Consolas" FontSize="12" Margin="10,2,5,2" VerticalAlignment="Center"/>
							
							<TextBox Grid.Column="1" 
							         Text="{Binding InputTerminal, UpdateSourceTrigger=PropertyChanged}"
							         Foreground="#FFFFFF" 
							         Background="Transparent"
							         BorderBrush="Transparent"
							         CaretBrush="White"
							         FontFamily="Consolas"
							         FontSize="12"
							         Margin="0,2,0,2">
								<TextBox.InputBindings>
									<KeyBinding Key="Return" Command="{Binding EnviarTerminalCommand}" />
								</TextBox.InputBindings>
							</TextBox>
							
							<Button Grid.Column="2" 
							        Content="Enviar" 
							        Command="{Binding EnviarTerminalCommand}"
							        Background="#3C3C3C" 
							        Foreground="White"
							        BorderBrush="Transparent"
							        Padding="5,1"
							        Margin="5,2,10,2"
							        FontSize="11"/>
						</Grid>
					</Grid>
				</Border>
			</Grid>

			<!-- ─────────────────────────────────── -->
			<!-- COL 2: Panel de tareas              -->
			<!-- RF-06: Visualización de tareas      -->
			<!-- RF-07: Ver detalles de tarea        -->
			<!-- ─────────────────────────────────── -->
			<Border Grid.Column="2" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1,0,0,0">
				<StackPanel Margin="8">
					<TextBlock Text="TAREAS" Foreground="#AAAAAA" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
					<!-- Aquí irá la lista de tareas y el botón de entrega (RF-06, RF-22) -->
					<TextBlock Text="[Panel de tareas — pendiente]" Foreground="#555" FontSize="11" TextWrapping="Wrap"/>
				</StackPanel>
			</Border>

		</Grid>

		<!-- ═══════════════════════════════════════════════════════ -->
		<!-- FILA 2: Barra de estado                               -->
		<!-- RF-11: muestra ruta del archivo y confirmación guardado -->
		<!-- Pendiente: tiempo de trabajo (RF-17), firma (RF-14)   -->
		<!-- ═══════════════════════════════════════════════════════ -->
		<Border Grid.Row="2" Background="#007ACC">
			<TextBlock Text="{Binding MensajeEstado}"
                       Foreground="White"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Margin="10,0"/>
		</Border>

	</Grid>
</Window>
