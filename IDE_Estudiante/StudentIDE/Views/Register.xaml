<Window x:Class="StudentIDE.Views.RegisterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StudentIDE — Registrarse"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" Background="#FF2B2B2A">

    <Grid>
        <TextBlock Text="Nombre completo"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Foreground="Gray" Margin="0,30,0,0" Height="30" Width="600" FontSize="24"/>
        <TextBox x:Name="NombreBox"
            HorizontalAlignment="Center" Height="45" Margin="0,60,0,0"
            TextWrapping="Wrap" VerticalAlignment="Top" Width="600"
            Background="#FF525252" Foreground="White" FontSize="24"
            MaxLines="1"/>

        <TextBlock Text="Correo electrónico"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Foreground="Gray" Margin="0,120,0,0" Height="30" Width="600" FontSize="24"/>
        <TextBox x:Name="EmailBox"
            HorizontalAlignment="Center" Height="45" Margin="0,150,0,0"
            TextWrapping="Wrap" VerticalAlignment="Top" Width="600"
            Background="#FF525252" Foreground="White" FontSize="24"
            MaxLines="1"/>

        <TextBlock Text="Contraseña (mín. 8 caracteres, mayúscula, número y símbolo)"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Foreground="Gray" Margin="0,210,0,0" Height="30" Width="600" FontSize="16"/>
        <PasswordBox x:Name="PasswordBox"
            HorizontalAlignment="Center" Height="45" Margin="0,240,0,0"
            VerticalAlignment="Top" Width="600"
            Background="#FF525252" Foreground="White" FontSize="24"/>

        <TextBlock Text="Carné (opcional)"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Foreground="Gray" Margin="0,300,0,0" Height="30" Width="600" FontSize="24"/>
        <TextBox x:Name="CarneBox"
            HorizontalAlignment="Center" Height="45" Margin="0,330,0,0"
            TextWrapping="Wrap" VerticalAlignment="Top" Width="600"
            Background="#FF525252" Foreground="White" FontSize="24"
            MaxLines="1"/>

        <Button x:Name="RegistrarseBtn"
            Content="Registrarse"
            HorizontalAlignment="Center" Height="55" Margin="0,410,0,0"
            VerticalAlignment="Top" Width="600"
            Click="Registrarse_Click"
            Background="#FF40407F" Foreground="#FF7F7FFF"
            BorderBrush="#FF7F7FFF" FontSize="28"/>

        <TextBlock x:Name="MensajeError"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Foreground="#FF4444" Margin="0,480,0,0"
            Height="40" Width="600" FontSize="18"
            TextAlignment="Center" Visibility="Collapsed"/>

        <TextBlock x:Name="MensajeExito"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Foreground="#44FF44" Margin="0,520,0,0"
            Height="40" Width="600" FontSize="18"
            TextAlignment="Center" Visibility="Collapsed"/>

        <Button x:Name="VolverBtn"
            Content="Volver"
            HorizontalAlignment="Center" Height="45" Margin="0,570,0,0"
            VerticalAlignment="Top" Width="600"
            Click="Volver_Click"
            Background="#FF1F1F3F" FontSize="22"
            BorderBrush="#FF7F7FFF" Foreground="#FF7F7FFF"/>
    </Grid>
</Window>
