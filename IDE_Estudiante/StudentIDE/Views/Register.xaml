<Window x:Class="StudentIDE.Views.RegisterView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StudentIDE — Registrarse"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" Background="#FF2B2B2A">

    <!--
        RF-01: Ingreso de estudiantes
        RF-28: Ingreso de profesor
    -->
    <Grid Background="#FF0B1626">
        <Button x:Name="RegisterBtn" Content="Registrarse" HorizontalAlignment="Left" Height="50" Margin="555,457,0,0" VerticalAlignment="Top" Width="535" Click="Button_Click" Background="#FF123A62" Foreground="White" BorderBrush="#007F7FFF" FontSize="36"/>
        <TextBox HorizontalAlignment="Left" Height="50" Margin="555,185,0,0" TextWrapping="Wrap" Text="Nombre" VerticalAlignment="Top" Width="535" TextChanged="TextBox_TextChanged" Background="White" MaxLines="1" Foreground="Black" FontSize="36"/>
        <TextBlock Text="Nombre de Usuario"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Foreground="Gray" Margin="555,143,0,0" Height="37" Width="535" FontSize="27"/>
        <TextBlock Text="Contraseña"
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Foreground="Gray" Margin="555,249,0,0" Height="32" Width="537" FontSize="27"/>
        <TextBox HorizontalAlignment="Left" Height="49" TextWrapping="Wrap" Text="Contraseña" VerticalAlignment="Top" Width="535" TextChanged="TextBox_TextChanged" Background="White" Foreground="Black" MaxLines="2147483638" FontSize="36" Margin="555,290,0,0"/>
        <TextBlock
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Foreground="Gray" Margin="556,358,0,0" Height="35" Width="535" FontSize="27"><Run Language="es-cr" Text="Correo electónico"/></TextBlock>
        <TextBox HorizontalAlignment="Left" Height="49" TextWrapping="Wrap" Text="Correo" VerticalAlignment="Top" Width="535" TextChanged="TextBox_TextChanged" Background="White" Foreground="Black" MaxLines="2147483638" FontSize="36" Margin="555,399,0,0"/>
        <Rectangle HorizontalAlignment="Left" Height="684" Stroke="#00000000" VerticalAlignment="Center" Width="550" Fill="#FF071223"/>
        <Image HorizontalAlignment="Left" Height="318" Margin="92,137,0,0" VerticalAlignment="Top" Width="398" Source="/Views/Logo.png"/>
        <TextBlock
            HorizontalAlignment="Left"
            VerticalAlignment="Top"
            Foreground="White" Margin="0,460,0,0" Height="50" Width="550" FontSize="36" TextAlignment="Center" FontFamily="Cascadia Code"><Run Language="es-cr" Text="Student IDE"/></TextBlock>

    </Grid>
</Window>
