<Window x:Class="StudentIDE.Views.LoginView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="StudentIDE — Iniciar sesión"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize" Background="#FF2B2B2A">

    <Grid>
        <TextBlock Text="Correo electrónico"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Foreground="Gray" Margin="0,60,0,0" Height="40" Width="600" FontSize="28"/>
        <TextBox x:Name="EmailBox"
            HorizontalAlignment="Center" Height="50" Margin="0,100,0,0"
            TextWrapping="Wrap" VerticalAlignment="Top" Width="600"
            Background="#FF525252" Foreground="White" FontSize="28"
            MaxLines="1"/>

        <TextBlock Text="Contraseña"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Foreground="Gray" Margin="0,190,0,0" Height="40" Width="600" FontSize="28"/>
        <PasswordBox x:Name="PasswordBox"
            HorizontalAlignment="Center" Height="50" Margin="0,230,0,0"
            VerticalAlignment="Top" Width="600"
            Background="#FF525252" Foreground="White" FontSize="28"/>

        <Button x:Name="IniciarSesionBtn"
            Content="Iniciar sesión"
            HorizontalAlignment="Center" Height="60" Margin="0,330,0,0"
            VerticalAlignment="Top" Width="600"
            Click="IniciarSesion_Click"
            Background="#FF40407F" Foreground="#FF7F7FFF"
            BorderBrush="#FF7F7FFF" FontSize="32"/>

        <TextBlock x:Name="MensajeError"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Foreground="#FF4444" Margin="0,420,0,0"
            Height="40" Width="600" FontSize="20"
            TextAlignment="Center" Visibility="Collapsed"/>

        <Button x:Name="VolverBtn"
            Content="Volver"
            HorizontalAlignment="Center" Height="50" Margin="0,480,0,0"
            VerticalAlignment="Top" Width="600"
            Click="Volver_Click"
            Background="#FF1F1F3F" FontSize="24"
            BorderBrush="#FF7F7FFF" Foreground="#FF7F7FFF"/>
    </Grid>
</Window>
