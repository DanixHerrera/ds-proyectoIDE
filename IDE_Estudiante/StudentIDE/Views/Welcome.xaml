<Window x:Class="StudentIDE.Views.WelcomeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome — Iniciar sesión"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize" Background="#FF2B2B2A">


    <Grid Background="#FF071223">

        <Button x:Name="RegistrarseBtn" Content="Registrarse" 
                HorizontalAlignment="Left" Height="85" Margin="209,454,0,0" VerticalAlignment="Top" Width="341" Click="RegistrarseBtn_Click" Background="#FF123A62" Foreground="White" BorderBrush="White" FontSize="54"/>

        <Button x:Name="IniciarSesionBtn" Content="Iniciar sesión" 
                HorizontalAlignment="Left" Height="85" Margin="588,454,0,0" VerticalAlignment="Top" Width="341" Click="LoginBtn_Click" Background="#FF123A62" Foreground="White" BorderBrush="White" FontSize="54"/>
        <Image HorizontalAlignment="Center" Height="288" VerticalAlignment="Top" Width="370" Source="/Views/Logo.png" Margin="0,30,0,0"/>
        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Foreground="White" Margin="0,342,0,0" Height="50" Width="550" FontSize="36" TextAlignment="Center" FontFamily="Cascadia Code"><Run Language="es-cr" Text="Crystal IDE"/></TextBlock>

    </Grid>
</Window>
