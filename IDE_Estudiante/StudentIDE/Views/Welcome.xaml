<Window x:Class="StudentIDE.Views.WelcomeView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Welcome — Iniciar sesión"
        Height="700" Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize" Background="#FF2B2B2A">


    <Grid Background="#FF071223">

        <Button x:Name="RegistrarseBtn" Content="Registrarse" 
                HorizontalAlignment="Center" Height="89" Margin="0,441,0,0" VerticalAlignment="Top" Width="408" Click="RegistrarseBtn_Click" Background="#FF123A62" Foreground="White" BorderBrush="White" FontSize="54"/>

        <Button x:Name="IniciarSesionBtn" Content="Iniciar sesión" 
                HorizontalAlignment="Center" Height="89" Margin="0,535,0,0" VerticalAlignment="Top" Width="408" Click="LoginBtn_Click" Background="#FF123A62" Foreground="White" BorderBrush="White" FontSize="54"/>
        <Image HorizontalAlignment="Left" Height="318" Margin="367,35,0,0" VerticalAlignment="Top" Width="398" Source="/Views/Logo.png"/>
        <TextBlock
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Foreground="White" Margin="0,358,0,0" Height="50" Width="550" FontSize="36" TextAlignment="Center" FontFamily="Cascadia Code"><Run Language="es-cr" Text="Student IDE"/></TextBlock>

    </Grid>
</Window>
