<Window x:Class="StudentIDE.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:converters="clr-namespace:StudentIDE.Converters"
        mc:Ignorable="d"
        Title="StudentIDE"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

	<Window.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
		<converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
	</Window.Resources>

	<!--
        ESTRUCTURA PRINCIPAL DE LA VENTANA
        - Barra superior (menu + acciones)
         - Zona central (panel de archivos | editor | terminal)
          -Barra de estado inferior
    -->
	<Grid>
		<Grid.RowDefinitions>
	
			<RowDefinition Height="40"/>
	
			<RowDefinition Height="*"/>
	
			<RowDefinition Height="25"/>
		</Grid.RowDefinitions>


		<!-- FILA 0: Barra superior  -->
		<Border Grid.Row="0" Background="#2D2D2D">
			<DockPanel LastChildFill="False" VerticalAlignment="Center" Margin="8,0">
				<StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
					<Button Content="📂 Abrir"
							Command="{Binding AbrirCommand}"
							Background="#3C3C3C"
							Foreground="White"
							BorderBrush="#555"
							Padding="10,4"
							Margin="0,0,8,0"
							Cursor="Hand"
							ToolTip="Abrir archivo"/>

					<Button Content="💾 Guardar"
							Command="{Binding GuardarCommand}"
							Background="#3C3C3C"
							Foreground="White"
							BorderBrush="#555"
							Padding="10,4"
							Margin="0,0,8,0"
							Cursor="Hand"
							ToolTip="Guardar archivo (Ctrl+S)"/>

					<Button Content="▶ Ejecutar"
							Command="{Binding EjecutarCommand}"
							Background="#3C3C3C"
							Foreground="White"
							BorderBrush="#555"
							Padding="10,4"
							Margin="0,0,8,0"
							Cursor="Hand"
							ToolTip="Ejecutar (F5)"/>
				</StackPanel>

				<Button Content="Cerrar sesión"
						x:Name="LogoutBtn"
						DockPanel.Dock="Right"
						Background="#8B0000"
						Foreground="White"
						BorderBrush="#555"
						Padding="10,4"
						Margin="0,0,8,0"
						Cursor="Hand"
						FontSize="13"
						Click="Logout_Click"/>
			</DockPanel>
		</Border>

		<!-- ═══════════════════════════════════════════ -->
		<!-- FILA 1: Zona central dividida en 3 columnas -->
		<!-- ═══════════════════════════════════════════ -->
		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
		
				<ColumnDefinition Width="200"/>
		
				<ColumnDefinition Width="*"/>
				
				<ColumnDefinition Width="340"/>
			</Grid.ColumnDefinitions>


			<!-- COL 0: Panel de archivos/proyectos  -->
			<Border Grid.Column="0" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,1,0">
				<StackPanel Margin="8">
					<TextBlock Text="EXPLORADOR" Foreground="#AAAAAA" FontSize="11" FontWeight="Bold" Margin="0,0,0,8"/>
					
                    
                    
					<TextBlock Text="[Panel de proyectos — pendiente]" Foreground="#555" FontSize="11" TextWrapping="Wrap"/>
				</StackPanel>
			</Border>

	
			<!-- COL 1: Editor de código             -->
			<Grid Grid.Column="1">
				<Grid.RowDefinitions>
			
					<RowDefinition Height="*"/>
				
					<RowDefinition Height="5"/>
		
					<RowDefinition Height="180"/>
				</Grid.RowDefinitions>


				<!-- COL 1: Editor de código — RF-05                        -->
				<avalonedit:TextEditor
                    x:Name="CodeEditor"
                    Grid.Row="0"
                    FontFamily="Consolas"
                    FontSize="14"
                    Background="#1E1E1E"
                    Foreground="#D4D4D4"
                    LineNumbersForeground="#858585"
                    ShowLineNumbers="True"
                    WordWrap="False"
                    IsReadOnly="False"
                    SyntaxHighlighting="Python"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto"
                    Padding="4,0,0,0"/>

				<!-- Divisor visual entre editor y terminal -->
				<GridSplitter Grid.Row="1" Height="5" HorizontalAlignment="Stretch" Background="#3C3C3C"/>

				<!-- Terminal interactiva (RF-16) — espacio reservado -->
				<Border Grid.Row="2" Background="#0C0C0C">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>
						
						<TextBlock Grid.Row="0" Text="TERMINAL" Foreground="#AAAAAA" FontSize="11" FontWeight="Bold" Margin="10,6,0,4"/>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
						    <TextBox Text="{Binding SalidaTerminal, Mode=OneWay}"
                                     Foreground="#CCCCCC" 
                                     Background="Transparent"
                                     BorderBrush="Transparent"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Margin="10,0"/>
                        </ScrollViewer>
						
						<Grid Grid.Row="2">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>
							
							<TextBlock Grid.Column="0" Text=">" Foreground="#00FF00" FontFamily="Consolas" FontSize="12" Margin="10,2,5,2" VerticalAlignment="Center"/>
							
							<TextBox Grid.Column="1" 
							         Text="{Binding InputTerminal, UpdateSourceTrigger=PropertyChanged}"
							         Foreground="#FFFFFF" 
							         Background="Transparent"
							         BorderBrush="Transparent"
							         CaretBrush="White"
							         FontFamily="Consolas"
							         FontSize="12"
							         Margin="0,2,0,2">
								<TextBox.InputBindings>
									<KeyBinding Key="Return" Command="{Binding EnviarTerminalCommand}" />
								</TextBox.InputBindings>
							</TextBox>
							
							<Button Grid.Column="2" 
							        Content="Enviar" 
							        Command="{Binding EnviarTerminalCommand}"
							        Background="#3C3C3C" 
							        Foreground="White"
							        BorderBrush="Transparent"
							        Padding="5,1"
							        Margin="5,2,10,2"
							        FontSize="11"/>
						</Grid>
					</Grid>
				</Border>
			</Grid>

			<!-- COL 2: Panel de tareas con detalle -->
			<Border Grid.Column="2" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1,0,0,0">
				<Grid Margin="8">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<!-- Header con botón Volver -->
					<Grid Grid.Row="0" Margin="0,0,0,8">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0" Text="TAREAS" Foreground="#AAAAAA" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
						<Button Grid.Column="1" Content="← Volver"
								Command="{Binding CerrarDetalleCommand}"
								Visibility="{Binding MostrarDetalleTarea, Converter={StaticResource BoolToVisibility}}"
								Background="Transparent" Foreground="#007ACC" BorderBrush="Transparent"
								FontSize="11" Cursor="Hand" Padding="4,2"/>
					</Grid>

					<!-- Lista + Detalle -->
					<Grid Grid.Row="1">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
						</Grid.RowDefinitions>

						<!-- Lista de tareas -->
						<ListBox Grid.Row="0"
								 ItemsSource="{Binding Tareas}"
								 SelectedItem="{Binding TareaSeleccionada}"
								 MaxHeight="260"
								 Background="Transparent" BorderBrush="#3C3C3C">
							<ListBox.ItemTemplate>
								<DataTemplate>
									<StackPanel Margin="0,4">
										<TextBlock Text="{Binding Titulo}" FontWeight="Bold" Foreground="White" FontSize="13" />
										<TextBlock Text="{Binding CursoNombre}" Foreground="#888" FontSize="12" />
									</StackPanel>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>

						<!-- Detalle de tarea seleccionada -->
						<ScrollViewer Grid.Row="1"
									  Visibility="{Binding MostrarDetalleTarea, Converter={StaticResource BoolToVisibility}}"
									  Margin="0,8,0,0"
									  VerticalScrollBarVisibility="Auto">
							<StackPanel>
								<TextBlock Text="{Binding TareaSeleccionada.Titulo}"
										   FontSize="18" FontWeight="Bold" Foreground="White"
										   TextWrapping="Wrap"/>

								<TextBlock Text="{Binding TareaSeleccionada.CursoNombre}"
										   Foreground="#888" FontSize="13" Margin="0,4,0,0"/>

								<TextBlock Margin="0,14,0,0" Foreground="#AAA" FontSize="12" Text="FECHA LÍMITE"/>
								<TextBlock Text="{Binding TareaSeleccionada.FechaLimite, StringFormat='{}{0:g}'}"
										   Foreground="#CCC" FontSize="13"/>

								<TextBlock Margin="0,10,0,0" Foreground="#AAA" FontSize="12" Text="ESTADO"/>
								<TextBlock Text="{Binding TareaSeleccionada.Estado}"
										   Foreground="#CCC" FontSize="13"/>

								<TextBlock Margin="0,14,0,0" Foreground="#AAA" FontSize="12" Text="INSTRUCCIONES"/>
								<Border Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="1"
										CornerRadius="4" Padding="12" Margin="0,4,0,0">
									<TextBlock Text="{Binding TareaSeleccionada.Instrucciones}"
											   Foreground="#CCC" FontSize="13"
											   TextWrapping="Wrap"/>
								</Border>

								<TextBlock Margin="0,14,0,0" Foreground="#AAA" FontSize="12" Text="ARCHIVO ADJUNTO"/>

								<Border Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="1"
										CornerRadius="4" Padding="12" Margin="0,4,0,0"
										Visibility="{Binding TareaSeleccionada.TieneArchivo, Converter={StaticResource BoolToVisibility}}">
									<Button Command="{Binding DescargarArchivoCommand}"
											Background="#3C3C3C" Foreground="White" BorderBrush="#555"
											Padding="12,8" Cursor="Hand" FontSize="14"
											HorizontalAlignment="Stretch" Content="Ver archivo adjunto"/>
								</Border>

								<Border Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="1"
										CornerRadius="4" Padding="12" Margin="0,4,0,0"
										Visibility="{Binding TareaSeleccionada.TieneArchivo, Converter={StaticResource InverseBoolToVisibility}}">
									<TextBlock Text="Sin archivo adjunto"
											   Foreground="#555" FontSize="12"
											   TextAlignment="Center"/>
								</Border>

								<TextBlock Margin="0,14,0,0" Foreground="#AAA" FontSize="12" Text="SOLUCIÓN"/>
								<Border Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="1"
										CornerRadius="4" Padding="16" Margin="0,4,0,0">
									<TextBlock Text="[Adjuntar solución — pendiente de implementar con panel de proyectos]"
											   Foreground="#555" FontSize="12"
											   TextWrapping="Wrap" TextAlignment="Center"/>
								</Border>
							</StackPanel>
						</ScrollViewer>
					</Grid>
				</Grid>
			</Border>

			</Grid>

		<!-- Barra de estado-->

		<Border Grid.Row="2" Background="#007ACC">
			<TextBlock Text="{Binding MensajeEstado}"
                       Foreground="White"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Margin="10,0"/>
		</Border>

	</Grid>
</Window>
