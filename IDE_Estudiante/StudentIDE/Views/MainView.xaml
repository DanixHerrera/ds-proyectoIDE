<Window x:Class="StudentIDE.Views.MainView"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonedit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:converters="clr-namespace:StudentIDE.Converters"
        mc:Ignorable="d"
        Title="StudentIDE"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize">

	<Window.Resources>
		<BooleanToVisibilityConverter x:Key="BoolToVisibility"/>
		<converters:InverseBoolToVisibilityConverter x:Key="InverseBoolToVisibility"/>
	</Window.Resources>

	<Grid>
		<Grid.RowDefinitions>
			<RowDefinition Height="40"/>
			<RowDefinition Height="*"/>
			<RowDefinition Height="25"/>
		</Grid.RowDefinitions>

		<!-- FILA 0: Barra superior -->
		<Border Grid.Row="0" Background="#2D2D2D">
			<DockPanel LastChildFill="False" VerticalAlignment="Center" Margin="8,0">
				<StackPanel Orientation="Horizontal" DockPanel.Dock="Left">
					<Button Content="📂 Abrir"
							Command="{Binding AbrirCommand}"
							Background="#3C3C3C"
							Foreground="White"
							BorderBrush="#555"
							Padding="10,4"
							Margin="0,0,8,0"
							Cursor="Hand"
							ToolTip="Abrir archivo"/>

					<Button Content="💾 Guardar"
							Command="{Binding GuardarCommand}"
							Background="#3C3C3C"
							Foreground="White"
							BorderBrush="#555"
							Padding="10,4"
							Margin="0,0,8,0"
							Cursor="Hand"
							ToolTip="Guardar archivo (Ctrl+S)"/>

					<Button Content="▶ Ejecutar"
							Command="{Binding EjecutarCommand}"
							Background="#3C3C3C"
							Foreground="White"
							BorderBrush="#555"
							Padding="10,4"
							Margin="0,0,8,0"
							Cursor="Hand"
							ToolTip="Ejecutar (F5)"/>
				</StackPanel>

				<Button Content="Cerrar sesión"
						x:Name="LogoutBtn"
						DockPanel.Dock="Right"
						Background="#8B0000"
						Foreground="White"
						BorderBrush="#555"
						Padding="10,4"
						Margin="0,0,8,0"
						Cursor="Hand"
						FontSize="13"
						Click="Logout_Click"/>
			</DockPanel>
		</Border>

		<!-- ═══════════════════════════════════════════ -->
		<!-- FILA 1: Zona central dividida en 3 columnas -->
		<Grid Grid.Row="1">
			<Grid.ColumnDefinitions>
				<ColumnDefinition Width="220"/>
				<ColumnDefinition Width="*"/>
				<ColumnDefinition Width="340"/>
			</Grid.ColumnDefinitions>

			<!-- COL 0: Panel de proyectos (TreeView) -->
			<Border Grid.Column="0" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="0,0,1,0">
				<Grid Margin="6">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<Grid Grid.Row="0" Margin="0,0,0,4">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0" Text="EXPLORADOR" Foreground="#AAA" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
						<Button Grid.Column="1" Content="+"
								Command="{Binding NuevoArchivoCommand}"
								Background="Transparent" Foreground="#AAA"
								BorderBrush="Transparent" FontSize="16"
								Cursor="Hand" Padding="4,0" ToolTip="Nuevo archivo"/>
						<Button Grid.Column="2" Content="📁"
								Command="{Binding NuevaCarpetaCommand}"
								Background="Transparent" Foreground="#AAA"
								BorderBrush="Transparent" FontSize="13"
								Cursor="Hand" Padding="4,0" ToolTip="Nueva carpeta"/>
						<Button Grid.Column="3" Content="📂"
								Command="{Binding AbrirProyectoCommand}"
								Background="Transparent" Foreground="#AAA"
								BorderBrush="Transparent" FontSize="13"
								Cursor="Hand" Padding="2" ToolTip="Abrir proyecto"/>
						<Button Grid.Column="4" Content="✕"
								Command="{Binding CerrarProyectoCommand}"
								Background="Transparent" Foreground="#AAA"
								BorderBrush="Transparent" FontSize="13"
								Cursor="Hand" Padding="2" ToolTip="Cerrar proyecto"/>
					</Grid>

					<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
						<TreeView x:Name="ProjectTree"
								  ItemsSource="{Binding ProjectRoots}"
								  BorderThickness="0"
								  Background="Transparent"
								  MouseDoubleClick="ProjectTree_MouseDoubleClick">
							<TreeView.ItemTemplate>
								<HierarchicalDataTemplate ItemsSource="{Binding Children}">
									<StackPanel Orientation="Horizontal">
										<TextBlock Text="📁 " Foreground="#E8A828" FontSize="12"
												   Visibility="{Binding IsDirectory, Converter={StaticResource BoolToVisibility}}"/>
										<TextBlock Text="📄 " Foreground="#569CD6" FontSize="12"
												   Visibility="{Binding IsDirectory, Converter={StaticResource InverseBoolToVisibility}}"/>
										<TextBlock Text="{Binding Name}" Foreground="#CCC" FontSize="12"/>
									</StackPanel>
								</HierarchicalDataTemplate>
							</TreeView.ItemTemplate>
						</TreeView>
					</ScrollViewer>
				</Grid>
			</Border>

			<!-- COL 1: Tab bar + Editor + Terminal -->
			<Grid Grid.Column="1">
				<Grid.RowDefinitions>
					<RowDefinition Height="28"/>
					<RowDefinition Height="*"/>
					<RowDefinition Height="5"/>
					<RowDefinition Height="180"/>
				</Grid.RowDefinitions>

				<!-- Tab bar -->
				<ListBox x:Name="TabBar"
						 Grid.Row="0"
						 ItemsSource="{Binding OpenTabs}"
						 SelectedItem="{Binding SelectedTab}"
						 Background="#1E1E1E"
						 BorderThickness="0,0,0,1"
						 BorderBrush="#3C3C3C"
						 FocusVisualStyle="{x:Null}">
					<ListBox.ItemsPanel>
						<ItemsPanelTemplate>
							<VirtualizingStackPanel IsItemsHost="True" Orientation="Horizontal"/>
						</ItemsPanelTemplate>
					</ListBox.ItemsPanel>
					<ListBox.ItemContainerStyle>
						<Style TargetType="ListBoxItem">
							<Setter Property="Background" Value="Transparent"/>
							<Setter Property="Padding" Value="0"/>
							<Setter Property="BorderThickness" Value="0"/>
							<Setter Property="FocusVisualStyle" Value="{x:Null}"/>
							<Style.Triggers>
								<Trigger Property="IsSelected" Value="True">
									<Setter Property="Background" Value="#2D2D2D"/>
								</Trigger>
							</Style.Triggers>
						</Style>
					</ListBox.ItemContainerStyle>
					<ListBox.ItemTemplate>
						<DataTemplate>
							<Border BorderBrush="#3C3C3C" BorderThickness="0,0,1,0" Padding="10,3">
								<StackPanel Orientation="Horizontal">
									<TextBlock Text="{Binding Header}" Foreground="#CCC" FontSize="12"/>
									<Button Content="×"
											Tag="{Binding}"
											Click="CloseTab_Click"
											Background="Transparent"
											Foreground="#777"
											BorderBrush="Transparent"
											FontSize="12"
											Margin="6,0,0,0"
											Padding="1,-1,1,-1"
											Cursor="Hand"
											ToolTip="Cerrar"/>
								</StackPanel>
							</Border>
						</DataTemplate>
					</ListBox.ItemTemplate>
				</ListBox>

				<!-- Editor de codigo -->
				<avalonedit:TextEditor
                    x:Name="CodeEditor"
                    Grid.Row="1"
                    FontFamily="Consolas"
                    FontSize="14"
                    Background="#1E1E1E"
                    Foreground="#D4D4D4"
                    LineNumbersForeground="#858585"
                    ShowLineNumbers="True"
                    WordWrap="False"
                    IsReadOnly="False"
                    SyntaxHighlighting="Python"
                    HorizontalScrollBarVisibility="Auto"
                    VerticalScrollBarVisibility="Auto"
                    Padding="4,0,0,0"/>

				<!-- Divisor -->
				<GridSplitter Grid.Row="2" Height="5" HorizontalAlignment="Stretch" Background="#3C3C3C"/>

				<!-- Terminal -->
				<Border Grid.Row="3" Background="#0C0C0C">
					<Grid>
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
							<RowDefinition Height="Auto"/>
						</Grid.RowDefinitions>

						<TextBlock Grid.Row="0" Text="TERMINAL" Foreground="#AAA" FontSize="11" FontWeight="Bold" Margin="10,6,0,4"/>
						<ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
							<TextBox Text="{Binding SalidaTerminal, Mode=OneWay}"
                                     Foreground="#CCC"
                                     Background="Transparent"
                                     BorderBrush="Transparent"
                                     IsReadOnly="True"
                                     TextWrapping="Wrap"
                                     AcceptsReturn="True"
                                     FontFamily="Consolas"
                                     FontSize="12"
                                     Margin="10,0"/>
						</ScrollViewer>

						<Grid Grid.Row="2">
							<Grid.ColumnDefinitions>
								<ColumnDefinition Width="Auto"/>
								<ColumnDefinition Width="*"/>
								<ColumnDefinition Width="Auto"/>
							</Grid.ColumnDefinitions>

							<TextBlock Grid.Column="0" Text=">" Foreground="#00FF00" FontFamily="Consolas" FontSize="12" Margin="10,2,5,2" VerticalAlignment="Center"/>

							<TextBox Grid.Column="1"
							         Text="{Binding InputTerminal, UpdateSourceTrigger=PropertyChanged}"
							         Foreground="#FFF"
							         Background="Transparent"
							         BorderBrush="Transparent"
							         CaretBrush="White"
							         FontFamily="Consolas"
							         FontSize="12"
							         Margin="0,2,0,2">
								<TextBox.InputBindings>
									<KeyBinding Key="Return" Command="{Binding EnviarTerminalCommand}"/>
								</TextBox.InputBindings>
							</TextBox>

							<Button Grid.Column="2"
							        Content="Enviar"
							        Command="{Binding EnviarTerminalCommand}"
							        Background="#3C3C3C"
							        Foreground="White"
							        BorderBrush="Transparent"
							        Padding="5,1"
							        Margin="5,2,10,2"
							        FontSize="11"/>
						</Grid>
					</Grid>
				</Border>
			</Grid>

			<!-- COL 2: Panel de tareas -->
			<Border Grid.Column="2" Background="#252526" BorderBrush="#3C3C3C" BorderThickness="1,0,0,0">
				<Grid Margin="8">
					<Grid.RowDefinitions>
						<RowDefinition Height="Auto"/>
						<RowDefinition Height="*"/>
					</Grid.RowDefinitions>

					<Grid Grid.Row="0" Margin="0,0,0,8">
						<Grid.ColumnDefinitions>
							<ColumnDefinition Width="*"/>
							<ColumnDefinition Width="Auto"/>
						</Grid.ColumnDefinitions>
						<TextBlock Grid.Column="0" Text="TAREAS" Foreground="#AAA" FontSize="11" FontWeight="Bold" VerticalAlignment="Center"/>
						<Button Grid.Column="1" Content="← Volver"
								Command="{Binding CerrarDetalleCommand}"
								Visibility="{Binding MostrarDetalleTarea, Converter={StaticResource BoolToVisibility}}"
								Background="Transparent" Foreground="#007ACC" BorderBrush="Transparent"
								FontSize="11" Cursor="Hand" Padding="4,2"/>
					</Grid>

					<Grid Grid.Row="1">
						<Grid.RowDefinitions>
							<RowDefinition Height="Auto"/>
							<RowDefinition Height="*"/>
						</Grid.RowDefinitions>

						<ListBox Grid.Row="0"
								 ItemsSource="{Binding Tareas}"
								 SelectedItem="{Binding TareaSeleccionada}"
								 MaxHeight="260"
								 Background="Transparent" BorderBrush="#3C3C3C">
							<ListBox.ItemTemplate>
								<DataTemplate>
									<StackPanel Margin="0,4">
										<TextBlock Text="{Binding Titulo}" FontWeight="Bold" Foreground="White" FontSize="13"/>
										<TextBlock Text="{Binding CursoNombre}" Foreground="#888" FontSize="12"/>
									</StackPanel>
								</DataTemplate>
							</ListBox.ItemTemplate>
						</ListBox>

						<ScrollViewer Grid.Row="1"
									  Visibility="{Binding MostrarDetalleTarea, Converter={StaticResource BoolToVisibility}}"
									  Margin="0,8,0,0"
									  VerticalScrollBarVisibility="Auto">
							<StackPanel>
								<TextBlock Text="{Binding TareaSeleccionada.Titulo}"
										   FontSize="18" FontWeight="Bold" Foreground="White"
										   TextWrapping="Wrap"/>
								<TextBlock Text="{Binding TareaSeleccionada.CursoNombre}"
										   Foreground="#888" FontSize="13" Margin="0,4,0,0"/>
								<TextBlock Margin="0,14,0,0" Foreground="#AAA" FontSize="12" Text="FECHA LÍMITE"/>
								<TextBlock Text="{Binding TareaSeleccionada.FechaLimite, StringFormat='{}{0:g}'}"
										   Foreground="#CCC" FontSize="13"/>
								<TextBlock Margin="0,10,0,0" Foreground="#AAA" FontSize="12" Text="ESTADO"/>
								<TextBlock Text="{Binding TareaSeleccionada.Estado}"
										   Foreground="#CCC" FontSize="13"/>
								<TextBlock Margin="0,14,0,0" Foreground="#AAA" FontSize="12" Text="INSTRUCCIONES"/>
								<Border Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="1"
										CornerRadius="4" Padding="12" Margin="0,4,0,0">
									<TextBlock Text="{Binding TareaSeleccionada.Instrucciones}"
											   Foreground="#CCC" FontSize="13" TextWrapping="Wrap"/>
								</Border>
								<TextBlock Margin="0,14,0,0" Foreground="#AAA" FontSize="12" Text="ARCHIVO ADJUNTO"/>
								<Border Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="1"
										CornerRadius="4" Padding="12" Margin="0,4,0,0"
										Visibility="{Binding TareaSeleccionada.TieneArchivo, Converter={StaticResource BoolToVisibility}}">
									<Button Command="{Binding DescargarArchivoCommand}"
											Background="#3C3C3C" Foreground="White" BorderBrush="#555"
											Padding="12,8" Cursor="Hand" FontSize="14"
											HorizontalAlignment="Stretch" Content="Ver archivo adjunto"/>
								</Border>
								<Border Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="1"
										CornerRadius="4" Padding="12" Margin="0,4,0,0"
										Visibility="{Binding TareaSeleccionada.TieneArchivo, Converter={StaticResource InverseBoolToVisibility}}">
									<TextBlock Text="Sin archivo adjunto"
											   Foreground="#555" FontSize="12"
											   TextAlignment="Center"/>
								</Border>
								<TextBlock Margin="0,14,0,0" Foreground="#AAA" FontSize="12" Text="SOLUCIÓN"/>

								<!-- Entregado: mostrar datos de la entrega -->
								<Border Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="1"
										CornerRadius="4" Padding="12" Margin="0,4,0,0"
										Visibility="{Binding TareaSeleccionada.TieneEntrega, Converter={StaticResource BoolToVisibility}}">
									<StackPanel>
										<TextBlock Foreground="#4EC9B0" FontSize="13" FontWeight="Bold" Text="✓ Entregada"/>
										<TextBlock Margin="0,4,0,0" Foreground="#888" FontSize="11" Text="{Binding TareaSeleccionada.UltimaEntregaArchivo, StringFormat='Archivo: {0}'}"/>
										<TextBlock Foreground="#888" FontSize="11" Text="{Binding TareaSeleccionada.UltimaEntregaTimestamp, StringFormat='Fecha: {0}'}"/>
										<Button Command="{Binding DescargarEntregaCommand}"
												Background="#3C3C3C" Foreground="White" BorderBrush="#555"
												Padding="12,8" Cursor="Hand" FontSize="13"
												HorizontalAlignment="Stretch" Margin="0,8,0,0"
												Content="Descargar entrega"/>
									</StackPanel>
								</Border>

								<!-- No entregado: boton para subir -->
								<Border Background="#1E1E1E" BorderBrush="#3C3C3C" BorderThickness="1"
										CornerRadius="4" Padding="12" Margin="0,4,0,0"
										Visibility="{Binding TareaSeleccionada.TieneEntrega, Converter={StaticResource InverseBoolToVisibility}}">
									<Button Command="{Binding SubirSolucionCommand}"
											Background="#3C3C3C" Foreground="White" BorderBrush="#555"
											Padding="12,8" Cursor="Hand" FontSize="14"
											HorizontalAlignment="Stretch" Content="Subir solución"/>
								</Border>
							</StackPanel>
						</ScrollViewer>
					</Grid>
				</Grid>
			</Border>
		</Grid>

		<!-- Barra de estado -->
		<Border Grid.Row="2" Background="#007ACC">
			<TextBlock Text="{Binding MensajeEstado}"
                       Foreground="White"
                       FontSize="11"
                       VerticalAlignment="Center"
                       Margin="10,0"/>
		</Border>
	</Grid>
</Window>
