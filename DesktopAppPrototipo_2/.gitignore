## .gitignore para proyecto .NET / WPF

# Carpetas de build y compilación
bin/
obj/

# Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docobj

# Archivos de publicación
publish/
*.pubxml
*.pubxml.user

# Paquetes NuGet (se restauran automáticamente)
packages/
*.nupkg
*.snupkg

# Logs y archivos temporales
*.log
*.tmp
*.temp
Thumbs.db
desktop.ini

# Archivos de cobertura de pruebas
*.coverage
*.coveragexml
TestResults/

# Archivos de entorno local (si se agregan más adelante)
.env
appsettings.Local.json
